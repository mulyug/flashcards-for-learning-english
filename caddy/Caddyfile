{$DOMAIN}:8443 {
    tls {
        dns cloudflare {$CLOUDFLARE_API_TOKEN}
    }

    encode gzip

    reverse_proxy app:8000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "same-origin"
        X-Frame-Options "DENY"
        -Server
    }
}
